# =============================================================================
# Section 11: Main Dispatch
# =============================================================================

parse_global_flags() {
    local args=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --verbose|-v)  VERBOSE=1; shift ;;
            --no-color)    NO_COLOR=1; shift ;;
            --force)       FORCE=1; shift ;;
            *)             args+=("$1"); shift ;;
        esac
    done
    GLOBAL_ARGS=("${args[@]+"${args[@]}"}")
}

main() {
    parse_global_flags "$@"
    set -- "${GLOBAL_ARGS[@]+"${GLOBAL_ARGS[@]}"}"

    local command="${1:-help}"
    shift || true

    case "$command" in
        create)   cmd_create "$@" ;;
        destroy)  cmd_destroy "$@" ;;
        list|ls)  cmd_list "$@" ;;
        status)   cmd_status "$@" ;;
        start)    cmd_start "$@" ;;
        stop)     cmd_stop "$@" ;;
        restart)  cmd_restart "$@" ;;
        logs)     cmd_logs "$@" ;;
        doctor)   cmd_doctor "$@" ;;
        token)    cmd_token "$@" ;;
        open)     cmd_open "$@" ;;
        pair)     cmd_pair "$@" ;;
        update)   cmd_update "$@" ;;
        chat)     cmd_chat "$@" ;;
        version)  cmd_version ;;
        help)     cmd_help "$@" ;;
        *)        error "Unknown command: ${command}"; echo ""; usage; exit 1 ;;
    esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
