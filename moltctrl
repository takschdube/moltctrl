# --- cmd_doctor ---
cmd_doctor() {
    echo "moltctrl doctor - Checking system requirements"
    echo "================================================"
    echo ""

    local issues=0

    # Docker
    printf '  %-20s' "Docker:"
    if command -v docker &>/dev/null; then
        local docker_version
        docker_version="$(docker --version 2>/dev/null | head -1)"
        if docker info &>/dev/null 2>&1; then
            success "$docker_version"
        else
            error "installed but daemon not running"
            issues=$((issues + 1))
        fi
    else
        error "not installed"
        issues=$((issues + 1))
    fi

    # Docker Compose v2
    printf '  %-20s' "Docker Compose:"
    if docker compose version &>/dev/null 2>&1; then
        local compose_version
        compose_version="$(docker compose version --short 2>/dev/null)"
        success "v${compose_version}"
    else
        error "not available (need Docker Compose v2)"
        issues=$((issues + 1))
    fi

    # jq
    printf '  %-20s' "jq:"
    if command -v jq &>/dev/null; then
        success "$(jq --version 2>/dev/null)"
    else
        error "not installed"
        issues=$((issues + 1))
    fi

    # envsubst
    printf '  %-20s' "envsubst:"
    if command -v envsubst &>/dev/null; then
        success "available"
    else
        error "not installed (gettext-base)"
        issues=$((issues + 1))
    fi

    # openssl
    printf '  %-20s' "openssl:"
    if command -v openssl &>/dev/null; then
        success "available"
    else
        warn "not installed (will use /dev/urandom fallback)"
    fi

    # websocat
    printf '  %-20s' "websocat:"
    if command -v websocat &>/dev/null; then
        success "available"
    else
        warn "not installed (needed for 'moltctrl chat')"
    fi

    echo ""
    if [[ "$issues" -eq 0 ]]; then
        success "All required dependencies are installed"
    else
        error "${issues} issue(s) found. Run install.sh to fix."
    fi

    return "$issues"
}

# --- cmd_token ---
cmd_token() {
    local name=""
    local regenerate=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --regenerate) regenerate=1; shift ;;
            -*)           die "Unknown option: $1" ;;
            *)
                if [[ -z "$name" ]]; then
                    name="$1"; shift
                else
                    die "Unexpected argument: $1"
                fi
                ;;
        esac
    done

    [[ -z "$name" ]] && die "Usage: moltctrl token <name> [--regenerate]"
    require_instance "$name"
    require_jq

    if [[ "$regenerate" -eq 1 ]]; then
        local new_token
        if command -v openssl &>/dev/null; then
            new_token="$(openssl rand -hex 32)"
        else
            new_token="$(head -c 32 /dev/urandom | od -An -tx1 | tr -d ' \n')"
        fi
        instance_set "$name" "token" "$new_token"

        # Update .env file
        local env_file
        env_file="$(instance_dir "$name")/.env"
        if [[ -f "$env_file" ]]; then
            local tmp_env="${env_file}.tmp"
            sed "s/^OPENCLAW_AUTH_TOKEN=.*/OPENCLAW_AUTH_TOKEN=${new_token}/" "$env_file" > "$tmp_env"
            mv "$tmp_env" "$env_file"
            chmod 600 "$env_file"
        fi

        success "Token regenerated. Restart the instance to apply."
        echo "$new_token"
    else
        local token
        token="$(instance_get "$name" "token")"
        if [[ -z "$token" ]]; then
            die "No token found for instance '${name}'"
        fi
        echo "$token"
    fi
}

