# --- cmd_pair ---
cmd_pair() {
    local subcmd="${1:-}"
    shift || true

    case "$subcmd" in
        approve) cmd_pair_approve "$@" ;;
        list)    cmd_pair_list "$@" ;;
        revoke)  cmd_pair_revoke "$@" ;;
        *)       die "Usage: moltctrl pair <approve|list|revoke> <name> [options]" ;;
    esac
}

cmd_pair_approve() {
    local name=""
    local label=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --label)  label="$2"; shift 2 ;;
            -*)       die "Unknown option: $1" ;;
            *)
                if [[ -z "$name" ]]; then
                    name="$1"; shift
                else
                    die "Unexpected argument: $1"
                fi
                ;;
        esac
    done

    [[ -z "$name" ]] && die "Usage: moltctrl pair approve <name> [--label LABEL]"
    require_instance "$name"
    require_jq

    # Generate a pairing key
    local key
    if command -v openssl &>/dev/null; then
        key="$(openssl rand -hex 16)"
    else
        key="$(head -c 16 /dev/urandom | od -An -tx1 | tr -d ' \n')"
    fi

    [[ -z "$label" ]] && label="key-$(date +%s)"

    # Add to paired_keys array
    local json_file
    json_file="$(instance_json "$name")"
    local tmp_file="${json_file}.tmp"
    jq --arg key "$key" --arg label "$label" \
        '.paired_keys += [{"key": $key, "label": $label, "created": (now | todate)}]' \
        "$json_file" > "$tmp_file"
    mv "$tmp_file" "$json_file"

    success "Pairing key created"
    echo "  Label: ${label}"
    echo "  Key:   ${key}"
}

cmd_pair_list() {
    local name=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -*) die "Unknown option: $1" ;;
            *)
                if [[ -z "$name" ]]; then
                    name="$1"; shift
                else
                    die "Unexpected argument: $1"
                fi
                ;;
        esac
    done

    [[ -z "$name" ]] && die "Usage: moltctrl pair list <name>"
    require_instance "$name"
    require_jq

    local json_file
    json_file="$(instance_json "$name")"
    local count
    count="$(jq '.paired_keys | length' "$json_file")"

    if [[ "$count" -eq 0 ]]; then
        info "No pairing keys for instance '${name}'"
        return 0
    fi

    printf '%-20s %-36s %s\n' "LABEL" "KEY" "CREATED"
    printf '%-20s %-36s %s\n' "-----" "---" "-------"
    jq -r '.paired_keys[] | [.label, .key, .created] | @tsv' "$json_file" | \
        while IFS=$'\t' read -r label key created; do
            printf '%-20s %-36s %s\n' "$label" "$key" "$created"
        done
}

cmd_pair_revoke() {
    local name=""
    local label=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --label)  label="$2"; shift 2 ;;
            -*)       die "Unknown option: $1" ;;
            *)
                if [[ -z "$name" ]]; then
                    name="$1"; shift
                else
                    die "Unexpected argument: $1"
                fi
                ;;
        esac
    done

    [[ -z "$name" ]] && die "Usage: moltctrl pair revoke <name> --label LABEL"
    [[ -z "$label" ]] && die "Usage: moltctrl pair revoke <name> --label LABEL"
    require_instance "$name"
    require_jq

    local json_file
    json_file="$(instance_json "$name")"
    local tmp_file="${json_file}.tmp"

    local before_count
    before_count="$(jq '.paired_keys | length' "$json_file")"

    jq --arg label "$label" '.paired_keys |= map(select(.label != $label))' "$json_file" > "$tmp_file"
    mv "$tmp_file" "$json_file"

    local after_count
    after_count="$(jq '.paired_keys | length' "$json_file")"

    if [[ "$before_count" -eq "$after_count" ]]; then
        warn "No pairing key with label '${label}' found"
    else
        success "Pairing key '${label}' revoked"
    fi
}

# --- cmd_update ---
cmd_update() {
    local name=""
    local model_flag=""
    local mem_flag=""
    local cpus_flag=""
    local pids_flag=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --model)  model_flag="$2"; shift 2 ;;
            --mem)    mem_flag="$2"; shift 2 ;;
            --cpus)   cpus_flag="$2"; shift 2 ;;
            --pids)   pids_flag="$2"; shift 2 ;;
            -*)       die "Unknown option: $1" ;;
            *)
                if [[ -z "$name" ]]; then
                    name="$1"; shift
                else
                    die "Unexpected argument: $1"
                fi
                ;;
        esac
    done

    [[ -z "$name" ]] && die "Usage: moltctrl update <name> [--model MODEL] [--mem MEM] [--cpus CPUS] [--pids PIDS]"
    require_instance "$name"
    require_jq

    local changed=0

    if [[ -n "$model_flag" ]]; then
        instance_set "$name" "model" "$model_flag"
        # Update .env
        local env_file
        env_file="$(instance_dir "$name")/.env"
        if [[ -f "$env_file" ]]; then
            local tmp_env="${env_file}.tmp"
            sed "s/^OPENCLAW_MODEL=.*/OPENCLAW_MODEL=${model_flag}/" "$env_file" > "$tmp_env"
            mv "$tmp_env" "$env_file"
            chmod 600 "$env_file"
        fi
        info "Model updated to: ${model_flag}"
        changed=1
    fi

    if [[ -n "$mem_flag" ]]; then
        instance_set "$name" "mem" "$mem_flag"
        info "Memory limit updated to: ${mem_flag}"
        changed=1
    fi

    if [[ -n "$cpus_flag" ]]; then
        instance_set "$name" "cpus" "$cpus_flag"
        info "CPU limit updated to: ${cpus_flag}"
        changed=1
    fi

    if [[ -n "$pids_flag" ]]; then
        instance_set "$name" "pids" "$pids_flag"
        info "PIDs limit updated to: ${pids_flag}"
        changed=1
    fi

    if [[ "$changed" -eq 0 ]]; then
        die "No updates specified. Use --model, --mem, --cpus, or --pids."
    fi

    # Re-render docker-compose.yml if resource limits changed
    if [[ -n "$mem_flag" ]] || [[ -n "$cpus_flag" ]] || [[ -n "$pids_flag" ]]; then
        local port image provider
        port="$(instance_get "$name" "port")"
        image="$(instance_get "$name" "image")"
        provider="$(instance_get "$name" "provider")"

        export MOLTCTRL_IMAGE="$image"
        export MOLTCTRL_CONTAINER_NAME="${MOLTCTRL_COMPOSE_PREFIX}-${name}"
        export MOLTCTRL_MEM_LIMIT="${mem_flag:-$(instance_get "$name" "mem")}"
        export MOLTCTRL_MEMSWAP_LIMIT="${mem_flag:-$(instance_get "$name" "mem")}"
        export MOLTCTRL_CPUS="${cpus_flag:-$(instance_get "$name" "cpus")}"
        export MOLTCTRL_PIDS_LIMIT="${pids_flag:-$(instance_get "$name" "pids")}"
        export MOLTCTRL_PORT="$port"
        local env_path
        env_path="$(instance_dir "$name")/.env"
        export MOLTCTRL_ENV_FILE="$env_path"
        export MOLTCTRL_VOLUME_PREFIX="${MOLTCTRL_COMPOSE_PREFIX}_${name}"

        local template=""
        if [[ -n "$MOLTCTRL_PROFILES_DIR" ]] && [[ -f "${MOLTCTRL_PROFILES_DIR}/openclaw.yml.tmpl" ]]; then
            template="${MOLTCTRL_PROFILES_DIR}/openclaw.yml.tmpl"
        fi
        if [[ -n "$template" ]]; then
            render_template "$template" "$(compose_file "$name")"
        fi
    fi

    warn "Restart the instance for changes to take effect: moltctrl restart ${name}"
}

# --- cmd_chat ---
cmd_chat() {
    local name=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -*) die "Unknown option: $1" ;;
            *)
                if [[ -z "$name" ]]; then
                    name="$1"; shift
                else
                    die "Unexpected argument: $1"
                fi
                ;;
        esac
    done

    [[ -z "$name" ]] && die "Usage: moltctrl chat <name>"
    require_instance "$name"
    require_jq

    if ! command -v websocat &>/dev/null; then
        die "websocat is required for chat. Install it: cargo install websocat"
    fi

    local port token
    port="$(instance_get "$name" "port")"
    token="$(instance_get "$name" "token")"

    local status
    status="$(compose_status "$name" 2>/dev/null)"
    if [[ "$status" != "running" ]]; then
        die "Instance '${name}' is not running (status: ${status}). Start it first."
    fi

    local url="ws://127.0.0.1:${port}/ws"
    info "Connecting to ${name} at ${url} ..."
    info "Press Ctrl+C to disconnect"
    echo ""

    websocat -H "Authorization: Bearer ${token}" "$url"
}

